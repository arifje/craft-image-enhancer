{# @var plugin \arjanbrinkman\craftimageenhancer\ImageEnhancer #}
{# @var settings \arjanbrinkman\craftimageenhancer\models\Settings #}

{% import '_includes/forms' as forms %}

<div id="tab-chatgpt">

	<h1>ChatGPT</h1>
	
	{{ forms.autosuggestField({
		label: 'ChatGPT API Key',
		name: 'chatGptApiKey',
		id: 'chatGptApiKey',
		instructions: 'Enter your OpenAI API key here or select an environment variable. This will be used to analyze images.',
		value: settings.chatGptApiKey,
		placeholder: 'sk-XXXXXXXXXXXXXXXXXXXXXXX',
		suggestEnvVars: true,
	}) }}
	
	{{ forms.textareaField({
		label: 'ChatGPT Prompt',
		name: 'chatGptPrompt',
		rows: 4,
		id: 'chatGptPrompt',
		instructions: 'The prompt that performs the photo analysis.',
		value: settings.chatGptPrompt,
		placeholder: '',
	}) }}
	
	{{ forms.selectField({
		label: 'ChatGPT Model',
		name: 'chatGptModel',
		id: 'chatGptModel',
		instructions: 'Choose a fixed OpenAI model, or use the latest available model for this API key.',
		value: settings.chatGptModel,
		options: chatGptModelOptions,
	}) }}
	
	{{ forms.selectField({
		label: 'Language of the ChatGPT result',
		instructions: 'Choose your language in which the result much be shown.',
		name: 'chatGptResultLanguage',
		value: settings.chatGptResultLanguage,
		options: [
			{ label: 'Nederlands', value: 'Dutch' },
			{ label: 'Engels', value: 'English' }
		]
	}) }}

</div>

<div id="tab-notifications" class="hidden">

	<h1>Slack</h1>
	
	{{ forms.textField({
		label: 'Threshold',
		name: 'notificationThreshold',
		id: 'notificationThreshold',
		instructions: 'Only send notification when image quality score is below a specific value',
		value: settings.notificationThreshold,
		placeholder: '',
	}) }}
	
	{{ forms.lightswitchField({
		label: "Send results to Slack"|t,
		id: 'slackNotification', 
		name: 'slackNotification',
		on: settings.slackNotification,
		instructions: "Also fill in the Slack variables below.",
	}) }}

	{{ forms.lightswitchField({
		label: "Send errors to Slack"|t,
		id: 'slackErrorNotification',
		name: 'slackErrorNotification',
		on: settings.slackErrorNotification,
		instructions: "Send failed image enhancement queue jobs to Slack using the same Slack variables below.",
	}) }}
	
	{{ forms.textField({
		label: 'Slack Bot Token',
		name: 'slackBotToken',
		id: 'slackBotToken',
		instructions: 'Enter your bot Token (see https://api.slack.com/apps, Oauth & permissions). Used when no webhook URL is configured.',
		value: settings.slackBotToken,
		placeholder: 'xoxb-xxx',
	}) }}
	
	{{ forms.textField({
		label: 'Slack Webhook URL',
		name: 'slackWebhookUrl',
		id: 'slackWebhookUrl',
		instructions: 'A Slack Webhook URL to receive notifications about image quality. If set, this is used before the bot token method.',
		value: settings.slackWebhookUrl,
		placeholder: 'https://hooks.slack.com/services/...',
	}) }}
	
	{{ forms.textField({
		label: 'Slack Channel',
		name: 'slackChannel',
		id: 'slackChannel',
		instructions: 'Specify a Slack channel or user here (e.g., #media or @john).',
		value: settings.slackChannel,
		placeholder: '#media'
	}) }}

	{{ forms.textField({
		label: 'Slack Error Channel',
		name: 'slackErrorChannel',
		id: 'slackErrorChannel',
		instructions: 'Optional channel for error notifications. Leave empty to use the normal Slack channel. For webhook delivery, the webhook may still control the destination channel.',
		value: settings.slackErrorChannel,
		placeholder: '#image-errors'
	}) }}

	<button type="button" class="btn" data-image-enhancer-test-action="craft-image-enhancer/notifications/test-slack">
		Send Slack test notifications
	</button>
	
	<hr />
	
	<h1>Email</h1>
	
	{{ forms.lightswitchField({
		label: "Send results by email"|t,
		id: 'emailNotification', 
		name: 'emailNotification',
		on: settings.emailNotification,
		instructions: "",
	}) }}
	
	{{ forms.textField({
		label: 'Email recipient',
		name: 'emailNotificationRecipient',
		id: 'emailNotificationRecipient',
		instructions: 'Add the email address of the recipient besides the author that uploaded the image.',
		value: settings.emailNotificationRecipient,
		placeholder: 'user@email.com'
	}) }}

	<button type="button" class="btn" data-image-enhancer-test-action="craft-image-enhancer/notifications/test-email">
		Send email test notification
	</button>

	<hr />

	<h1>Debug</h1>

	{{ forms.lightswitchField({
		label: "Enable debug logging"|t,
		id: 'debugLogging',
		name: 'debugLogging',
		on: settings.debugLogging,
		instructions: "Writes ImageEnhancer DEBUG lines to Craft's web.log for troubleshooting queue jobs.",
	}) }}

</div>

{% js %}
	(() => {
		const buttons = document.querySelectorAll('[data-image-enhancer-test-action]');
		buttons.forEach((button) => {
			button.addEventListener('click', async () => {
				const originalText = button.textContent;
				button.disabled = true;
				button.textContent = 'Sending...';

				try {
					const response = await Craft.sendActionRequest('POST', button.dataset.imageEnhancerTestAction);
					const message = response.data?.message || 'Test notification sent.';

					if (response.data?.success) {
						Craft.cp.displayNotice(message);
					} else {
						Craft.cp.displayError(message);
					}
				} catch (error) {
					Craft.cp.displayError(error?.response?.data?.message || error?.message || 'Test notification failed.');
				} finally {
					button.disabled = false;
					button.textContent = originalText;
				}
			});
		});
	})();
{% endjs %}

<div id="tab-enhancement" class="hidden">

	<h1>Enhancement</h1>

	{{ forms.selectField({
		label: 'Enhancement mode',
		name: 'imageEnhancementMode',
		id: 'imageEnhancementMode',
		instructions: 'When an image score is below the notification threshold, choose whether replacement is handled by Imagick or an AI image provider.',
		value: settings.imageEnhancementMode,
		options: imageEnhancementModeOptions,
	}) }}

	{{ forms.selectField({
		label: 'Enhancement trigger',
		name: 'imageEnhancementTrigger',
		id: 'imageEnhancementTrigger',
		instructions: 'Choose whether enhancement only runs after the quality score reaches the threshold, or always runs immediately without the quality check.',
		value: settings.imageEnhancementTrigger,
		options: imageEnhancementTriggerOptions,
	}) }}

	{{ forms.selectField({
		label: 'Enhanced image handling',
		name: 'imageEnhancementAction',
		id: 'imageEnhancementAction',
		instructions: 'Choose whether the enhanced file replaces the original asset or is added next to the original asset for manual review.',
		value: settings.imageEnhancementAction,
		options: imageEnhancementActionOptions,
	}) }}

	{{ forms.selectField({
		label: 'AI image provider',
		name: 'imageEnhancementProvider',
		id: 'imageEnhancementProvider',
		instructions: 'Choose the platform used for AI image enhancement. OpenAI uses the ChatGPT API key from the ChatGPT tab. Choose in frontend lets editors pick the provider and model in the frontend enhancement component.',
		value: settings.imageEnhancementProvider,
		options: imageEnhancementProviderOptions,
	}) }}

	<div class="image-enhancer-provider-settings">
		<div class="image-enhancer-provider-settings__intro">
			<h2>Provider credentials and models</h2>
			<p>Only the selected provider is shown here. When editors can choose in the frontend, all configured providers are shown in this compact overview.</p>
		</div>

		<div class="image-enhancer-provider-grid">
			<div class="image-enhancer-provider-card" data-image-enhancement-provider-fields="openai">
				<div class="image-enhancer-provider-card__header">
					<h3>OpenAI</h3>
					<p>Uses the ChatGPT API key from the ChatGPT tab.</p>
				</div>

				{{ forms.selectField({
					label: 'Image model',
					name: 'imageEnhancementModel',
					id: 'imageEnhancementModel',
					instructions: 'Used for OpenAI image enhancement.',
					value: settings.imageEnhancementModel,
					options: imageEnhancementModelOptions,
				}) }}
			</div>

			<div class="image-enhancer-provider-card" data-image-enhancement-provider-fields="xai">
				<div class="image-enhancer-provider-card__header">
					<h3>Grok Imagine</h3>
					<p>Requires an xAI API key.</p>
				</div>

				{{ forms.autosuggestField({
					label: 'API key',
					name: 'xAiApiKey',
					id: 'xAiApiKey',
					instructions: 'Stored in project config and used for Grok Imagine requests. Environment variables are supported.',
					value: settings.xAiApiKey,
					placeholder: 'xai-...',
					suggestEnvVars: true,
				}) }}

				{{ forms.selectField({
					label: 'Image model',
					name: 'xAiImageEnhancementModel',
					id: 'xAiImageEnhancementModel',
					instructions: 'Used for Grok Imagine image enhancement.',
					value: settings.xAiImageEnhancementModel,
					options: xAiImageEnhancementModelOptions,
				}) }}
			</div>

			<div class="image-enhancer-provider-card" data-image-enhancement-provider-fields="google">
				<div class="image-enhancer-provider-card__header">
					<h3>Google Nano Banana</h3>
					<p>Requires a Google AI API key.</p>
				</div>

				{{ forms.autosuggestField({
					label: 'API key',
					name: 'googleAiApiKey',
					id: 'googleAiApiKey',
					instructions: 'Stored in project config and used for Google image requests. Environment variables are supported.',
					value: settings.googleAiApiKey,
					placeholder: 'AIza...',
					suggestEnvVars: true,
				}) }}

				{{ forms.selectField({
					label: 'Image model',
					name: 'googleImageEnhancementModel',
					id: 'googleImageEnhancementModel',
					instructions: 'Used for Google Nano Banana image enhancement.',
					value: settings.googleImageEnhancementModel,
					options: googleImageEnhancementModelOptions,
				}) }}
			</div>
		</div>
	</div>

	{% js %}
		(() => {
			const providerSelect = document.querySelector('select[name="imageEnhancementProvider"], select[name$="[imageEnhancementProvider]"]');
			const providerFields = document.querySelectorAll('[data-image-enhancement-provider-fields]');
			const providerGrid = document.querySelector('.image-enhancer-provider-grid');

			if (!providerSelect || !providerFields.length) {
				return;
			}

			const updateProviderFields = () => {
				const showAll = providerSelect.value === 'frontend';
				providerGrid?.classList.toggle('image-enhancer-provider-grid--all', showAll);
				providerFields.forEach((field) => {
					const isActive = showAll || field.dataset.imageEnhancementProviderFields === providerSelect.value;
					field.hidden = !isActive;
					field.classList.toggle('hidden', !isActive);
				});
			};

			providerSelect.addEventListener('change', updateProviderFields);
			providerSelect.addEventListener('input', updateProviderFields);
			updateProviderFields();
		})();
	{% endjs %}

	{% css %}
		.image-enhancer-provider-settings {
			margin: 24px 0 32px;
			max-width: 1180px;
		}

		.image-enhancer-provider-settings__intro {
			margin-bottom: 12px;
		}

		.image-enhancer-provider-settings__intro h2 {
			margin: 0 0 4px;
		}

		.image-enhancer-provider-settings__intro p,
		.image-enhancer-provider-card__header p {
			margin: 0;
			color: #596673;
		}

		.image-enhancer-provider-grid {
			display: grid;
			grid-template-columns: minmax(280px, 520px);
			gap: 16px;
		}

		.image-enhancer-provider-grid--all {
			grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		}

		.image-enhancer-provider-card {
			padding: 16px;
			border: 1px solid #dce3ea;
			border-radius: 8px;
			background: #f7f9fb;
		}

		.image-enhancer-provider-card[hidden] {
			display: none !important;
		}

		.image-enhancer-provider-card__header {
			margin-bottom: 14px;
		}

		.image-enhancer-provider-card__header h3 {
			margin: 0 0 3px;
			font-size: 16px;
		}

		.image-enhancer-provider-card .field {
			margin: 0 0 14px;
		}

		.image-enhancer-provider-card .field:last-child {
			margin-bottom: 0;
		}

		.image-enhancer-provider-card input.text,
		.image-enhancer-provider-card select {
			width: 100%;
			max-width: 100%;
		}
	{% endcss %}

	{{ forms.selectField({
		label: 'AI face handling',
		name: 'imageEnhancementFaceHandling',
		id: 'imageEnhancementFaceHandling',
		instructions: 'Choose whether AI enhancement can run when visible human faces are detected.',
		value: settings.imageEnhancementFaceHandling,
		options: imageEnhancementFaceHandlingOptions,
	}) }}

	{{ forms.textareaField({
		label: 'Face blur detection prompt',
		name: 'faceBlurDetectionPrompt',
		id: 'faceBlurDetectionPrompt',
		rows: 8,
		instructions: 'Default prompt used by the Blur faces frontend action. The prompt must return JSON face/head boxes; Imagick applies the actual blur locally. Production can override this from Utilities > Image Enhancer.',
		value: settings.effectiveFaceBlurDetectionPrompt,
	}) }}

	<hr>

	<h2>Failed job retry</h2>

	{{ forms.lightswitchField({
		label: 'Retry failed enhancement jobs',
		id: 'retryFailedEnhancementJobs',
		name: 'retryFailedEnhancementJobs',
		on: settings.retryFailedEnhancementJobs,
		instructions: 'When enabled, a failed article image enhancement queue job gets one delayed retry before the error is reported.',
	}) }}

	{{ forms.textField({
		label: 'Retry delay',
		name: 'failedEnhancementRetryDelay',
		id: 'failedEnhancementRetryDelay',
		type: 'number',
		min: 0,
		max: 86400,
		step: 1,
		size: 6,
		unit: 'seconds',
		instructions: 'How many seconds to wait before retrying a failed enhancement job.',
		value: settings.failedEnhancementRetryDelay,
		placeholder: '60',
	}) }}

	<hr>

	<h2>AI tuning levels</h2>

	{{ forms.textField({
		label: 'Clarity / detail',
		name: 'creativeEnhancementClarityLevel',
		id: 'creativeEnhancementClarityLevel',
		type: 'number',
		min: 1,
		max: 10,
		step: 1,
		size: 4,
		instructions: '1 is very subtle, 5 is balanced, 10 is strong but still natural. Controls sharpness, deblurring, edge definition, and visible texture detail.',
		value: settings.creativeEnhancementClarityLevel,
		placeholder: '5',
	}) }}

	{{ forms.textField({
		label: 'Contrast / depth',
		name: 'creativeEnhancementContrastLevel',
		id: 'creativeEnhancementContrastLevel',
		type: 'number',
		min: 1,
		max: 10,
		step: 1,
		size: 4,
		instructions: '1 is very subtle, 5 is balanced, 10 is strong but still natural. Controls contrast, dynamic range, and perceived depth.',
		value: settings.creativeEnhancementContrastLevel,
		placeholder: '5',
	}) }}

	{{ forms.textField({
		label: 'Color intensity',
		name: 'creativeEnhancementColorLevel',
		id: 'creativeEnhancementColorLevel',
		type: 'number',
		min: 1,
		max: 10,
		step: 1,
		size: 4,
		instructions: '1 is muted, 5 is balanced, 10 is vivid but still natural. Controls saturation, vibrance, and color richness.',
		value: settings.creativeEnhancementColorLevel,
		placeholder: '5',
	}) }}

	{{ forms.textField({
		label: 'Noise / artifact cleanup',
		name: 'creativeEnhancementNoiseReductionLevel',
		id: 'creativeEnhancementNoiseReductionLevel',
		type: 'number',
		min: 1,
		max: 10,
		step: 1,
		size: 4,
		instructions: '1 is very light cleanup, 5 is balanced, 10 is aggressive but should still preserve real skin texture and natural grain.',
		value: settings.creativeEnhancementNoiseReductionLevel,
		placeholder: '5',
	}) }}

	{{ forms.textField({
		label: 'Imagick safe optimization max width',
		name: 'safeEnhancementMaxWidth',
		id: 'safeEnhancementMaxWidth',
		instructions: 'Imagick safe optimization can upscale smaller images up to this width while preserving the original aspect ratio.',
		value: settings.safeEnhancementMaxWidth,
		placeholder: '2400',
	}) }}

	{{ forms.textField({
		label: 'Imagick JPEG quality',
		name: 'safeEnhancementJpegQuality',
		id: 'safeEnhancementJpegQuality',
		instructions: 'JPEG compression quality used when Imagick rewrites a JPEG file.',
		value: settings.safeEnhancementJpegQuality,
		placeholder: '90',
	}) }}

	{{ forms.textareaField({
		label: 'AI enhancement prompt',
		name: 'creativeEnhancementPrompt',
		id: 'creativeEnhancementPrompt',
		rows: 16,
		instructions: 'Default prompt used for AI enhancement mode across all providers. Keep this strict if context must be preserved. For visible faces, preserve identity over sharpness and avoid inventing details. Production can override this from Utilities > Image Enhancer.',
		value: settings.effectiveCreativeEnhancementPrompt,
	}) }}

</div>

<div id="tab-volumes"  class="hidden">
	
	<h1>Asset Volumes</h1>

	{{ forms.lightswitchField({
		label: 'Assist image uploads that do not meet field requirements',
		id: 'enableUploadRequirementAssistant',
		name: 'enableUploadRequirementAssistant',
		on: settings.enableUploadRequirementAssistant,
		instructions: 'For the configured CP asset fields, keep repairable image uploads temporarily and show editors a resize or AI enhancement workflow instead of only reporting that the asset is not selectable.',
	}) }}
	
	{% set allVolumes = craft.app.volumes.allVolumes %}
	
	{% set volumeOptions = [] %}
	{% for volume in allVolumes %}
		{% set volumeOptions = volumeOptions|merge([{
			label: volume.name ~ ' (' ~ volume.handle ~ ')',
			value: volume.handle,
			checked: volume.handle in settings.allowedAssetFieldHandles
		}]) %}
	{% endfor %}
	
	{{ forms.checkboxGroupField({
		label: 'Only run the analyses on these asset volumes',
		instructions: 'Select your volumes that should be analysed.',
		name: 'allowedAssetFieldHandles',
		options: volumeOptions
	}) }}

	<hr>

	{% set cpEnhancerAssetFieldOptions = [] %}
	{% for option in assetFieldOptions %}
		{% set cpEnhancerAssetFieldOptions = cpEnhancerAssetFieldOptions|merge([option|merge({
			checked: option.value in settings.cpEnhancerAssetFieldHandles
		})]) %}
	{% endfor %}

	{{ forms.checkboxGroupField({
		label: 'Enable Image Enhancer tools in these asset fields',
		instructions: 'Select the asset fields that should show the Enhance link and, when enabled above, the upload requirement assistant. If nothing is selected, the tools are limited to top-level asset fields and hidden inside Matrix/nested fields.',
		name: 'cpEnhancerAssetFieldHandles',
		options: cpEnhancerAssetFieldOptions
	}) }}
</div>
